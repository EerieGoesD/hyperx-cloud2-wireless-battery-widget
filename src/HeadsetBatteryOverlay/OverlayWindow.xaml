<!-- OverlayWindow.xaml -->
<Window x:Class="HeadsetBatteryOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Headset Battery Overlay"
        Icon="tray.ico"
        Width="300" Height="138"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        SizeToContent="Manual"
        MinWidth="0" MinHeight="0">

    <Border x:Name="RootBorder"
            CornerRadius="10"
            Background="#E60A0A0C"
            Padding="10"
            BorderBrush="#44222228"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="ColSpacer" Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="LeftPanel" Grid.Column="0" VerticalAlignment="Center">
                <Viewbox Width="34" Height="34" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid Width="24" Height="24">
                        <Border CornerRadius="2" BorderBrush="#D4D4D8" BorderThickness="2" Background="Transparent" Margin="0,2,3,2"/>
                        <Border CornerRadius="1" Background="#D4D4D8" Width="4" Height="8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <Rectangle x:Name="BatteryFill" Fill="LimeGreen" Margin="3,5,6,5" RadiusX="1" RadiusY="1" HorizontalAlignment="Stretch"/>
                    </Grid>
                </Viewbox>

                <TextBlock Margin="0,6,0,0" FontSize="10" HorizontalAlignment="Center">
                    <Run Text="Made by " Foreground="#63636E"/><Hyperlink NavigateUri="https://eeriegoesd.com" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#818CF8" TextDecorations="">EERIE</Hyperlink>
                </TextBlock>

                <TextBlock Margin="0,2,0,0" FontSize="10" HorizontalAlignment="Center">
                    <Hyperlink NavigateUri="https://buymeacoffee.com/eeriegoesd" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#EAB308" TextDecorations="">Buy Me a Coffee</Hyperlink>
                </TextBlock>

                <TextBlock Margin="0,2,0,0" FontSize="10" HorizontalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/EerieGoesD/hyperx-cloud2-wireless-battery-widget/issues" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#63636E" TextDecorations="">Report Issue</Hyperlink>
                </TextBlock>

                <TextBlock Margin="0,2,0,0" FontSize="10" HorizontalAlignment="Center">
                    <Hyperlink NavigateUri="https://github.com/EerieGoesD/hyperx-cloud2-wireless-battery-widget/discussions/" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#63636E" TextDecorations="">Feedback</Hyperlink>
                </TextBlock>
            </StackPanel>

            <StackPanel x:Name="RightPanel" Grid.Column="2" VerticalAlignment="Center">
                <StackPanel x:Name="PercentRow" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="PercentText" Text="--%" Foreground="#D4D4D8" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button x:Name="BtnCompact" Content="-" Width="18" Height="18" FontSize="12"
                            Padding="0" Margin="8,0,0,0"
                            Background="Transparent" Foreground="#D4D4D8"
                            BorderBrush="#55FFFFFF" BorderThickness="1"
                            Click="BtnCompact_Click"/>
                    <Button x:Name="BtnExpand" Content="+" Width="18" Height="18" FontSize="12"
                            Padding="0" Margin="6,0,0,0"
                            Background="Transparent" Foreground="#D4D4D8"
                            BorderBrush="#55FFFFFF" BorderThickness="1"
                            Click="BtnExpand_Click"
                            Visibility="Collapsed"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" Text="Starting..." Foreground="#8B8B96" FontSize="11" TextTrimming="CharacterEllipsis"/>

                <CheckBox x:Name="ChkTopmost" Content="Always on Top" IsChecked="True" Margin="0,6,0,0"
                          Foreground="#8B8B96" FontSize="10"
                          Checked="ChkTopmost_Changed" Unchecked="ChkTopmost_Changed">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal">
                                            <Border x:Name="Box" Width="14" Height="14" CornerRadius="3"
                                                    Background="#1A1A1F" BorderBrush="#333" BorderThickness="1"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="Check" Text="✓" FontSize="10" FontWeight="Bold"
                                                           Foreground="#818CF8" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="Collapsed"/>
                                            </Border>
                                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="Box" Property="BorderBrush" Value="#818CF8"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Box" Property="BorderBrush" Value="#444"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>
            </StackPanel>
        </Grid>
    </Border>
</Window>